# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configuration (OpenRouter model ID)
# Options: anthropic/claude-3.5-haiku, anthropic/claude-3.5-sonnet, openai/gpt-4o, etc.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Browser Configuration
HEADLESS=true               # Set to false to see the browser in action
BROWSER_TIMEOUT=30000       # Timeout in milliseconds (30s default)
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Agent Configuration
MAX_STEPS=20                # Max number of agent decision steps
SCREENSHOT_DIR=./screenshots
LOG_DIR=./logs
LOG_LEVEL=info              # debug | info | warn | error

# Target Configuration
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
